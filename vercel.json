{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "maxLambdaSize": "50mb",
        "includeFiles": ["public/**"]
      }
    }
  ],
  "routes": [
    {
      "src": "^/public/(.*)",
      "dest": "/public/$1"
    },
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/tmdb-sync",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/tmdb-cleanup",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/token-cleanup",
      "schedule": "0 5 * * *"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
