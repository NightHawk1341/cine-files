// ============================================================
// CineFiles Prisma Schema
// Matches SQL_SCHEMA.sql — PostgreSQL via Supabase
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// USERS & AUTH
// ============================================================

model User {
  id             Int       @id @default(autoincrement())
  yandexId       String?   @unique @map("yandex_id") @db.VarChar(50)
  vkId           String?   @unique @map("vk_id") @db.VarChar(50)
  telegramId     String?   @unique @map("telegram_id") @db.VarChar(50)
  email          String?   @db.VarChar(255)
  displayName    String?   @map("display_name") @db.VarChar(100)
  avatarUrl      String?   @map("avatar_url")
  loginMethod    String    @map("login_method") @db.VarChar(20)
  role           String    @default("reader") @db.VarChar(20)
  tributeUserId  Int?      @map("tribute_user_id")
  preferences    Json      @default("{}")
  createdAt      DateTime  @default(now()) @map("created_at")
  lastLoginAt    DateTime? @map("last_login_at")

  authTokens AuthToken[]
  articles   Article[]
  comments   Comment[]
  media      Media[]

  @@map("users")
}

model AuthToken {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  refreshToken String   @unique @map("refresh_token") @db.VarChar(500)
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("auth_tokens")
}

// ============================================================
// CONTENT
// ============================================================

model Category {
  id          Int      @id @default(autoincrement())
  slug        String   @unique @db.VarChar(50)
  nameRu      String   @map("name_ru") @db.VarChar(100)
  nameEn      String?  @map("name_en") @db.VarChar(100)
  description String?
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")

  articles Article[]

  @@map("categories")
}

model Article {
  id                Int       @id @default(autoincrement())
  slug              String    @unique @db.VarChar(200)
  categoryId        Int       @map("category_id")
  authorId          Int       @map("author_id")
  title             String    @db.VarChar(300)
  subtitle          String?   @db.VarChar(500)
  lead              String?
  body              Json
  coverImageUrl     String?   @map("cover_image_url")
  coverImageAlt     String?   @map("cover_image_alt") @db.VarChar(300)
  coverImageCredit  String?   @map("cover_image_credit") @db.VarChar(200)
  metaTitle         String?   @map("meta_title") @db.VarChar(70)
  metaDescription   String?   @map("meta_description") @db.VarChar(160)
  canonicalUrl      String?   @map("canonical_url")
  status            String    @default("draft") @db.VarChar(20)
  publishedAt       DateTime? @map("published_at")
  updatedAt         DateTime? @map("updated_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  viewCount         Int       @default(0) @map("view_count")
  commentCount      Int       @default(0) @map("comment_count")
  tributeProductIds Int[]     @default([]) @map("tribute_product_ids")
  isFeatured        Boolean   @default(false) @map("is_featured")
  isPinned          Boolean   @default(false) @map("is_pinned")
  allowComments     Boolean   @default(true) @map("allow_comments")

  category           Category            @relation(fields: [categoryId], references: [id])
  author             User                @relation(fields: [authorId], references: [id])
  tags               ArticleTag[]
  comments           Comment[]
  collectionArticles CollectionArticle[]

  @@index([slug])
  @@index([status])
  @@index([categoryId])
  @@index([authorId])
  @@index([publishedAt(sort: Desc)])
  @@index([isFeatured])
  @@map("articles")
}

// ============================================================
// TAGGING SYSTEM (TMDB-powered)
// ============================================================

model TmdbEntity {
  id           Int      @id @default(autoincrement())
  tmdbId       Int      @map("tmdb_id")
  entityType   String   @map("entity_type") @db.VarChar(20)
  titleRu      String?  @map("title_ru")
  titleEn      String?  @map("title_en")
  metadata     Json
  credits      Json?
  lastSyncedAt DateTime @default(now()) @map("last_synced_at")
  createdAt    DateTime @default(now()) @map("created_at")

  tags Tag[]

  @@unique([tmdbId, entityType], name: "tmdbId_entityType")
  @@index([entityType])
  @@index([tmdbId])
  @@map("tmdb_entities")
}

model Tag {
  id            Int      @id @default(autoincrement())
  slug          String   @unique @db.VarChar(100)
  nameRu        String   @map("name_ru") @db.VarChar(150)
  nameEn        String?  @map("name_en") @db.VarChar(150)
  tagType       String   @map("tag_type") @db.VarChar(30)
  tmdbEntityId  Int?     @map("tmdb_entity_id")
  articleCount  Int      @default(0) @map("article_count")
  createdAt     DateTime @default(now()) @map("created_at")

  tmdbEntity TmdbEntity? @relation(fields: [tmdbEntityId], references: [id])
  articles   ArticleTag[]

  @@index([tagType])
  @@index([slug])
  @@map("tags")
}

model ArticleTag {
  articleId Int     @map("article_id")
  tagId     Int     @map("tag_id")
  isPrimary Boolean @default(false) @map("is_primary")

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
  @@index([tagId])
  @@map("article_tags")
}

// ============================================================
// COMMENTS
// ============================================================

model Comment {
  id        Int       @id @default(autoincrement())
  articleId Int       @map("article_id")
  userId    Int       @map("user_id")
  parentId  Int?      @map("parent_id")
  body      String
  status    String    @default("visible") @db.VarChar(20)
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @map("updated_at")

  article Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user    User     @relation(fields: [userId], references: [id])
  parent  Comment? @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies Comment[] @relation("CommentReplies")

  @@index([articleId])
  @@index([userId])
  @@index([parentId])
  @@map("comments")
}

// ============================================================
// TMDB CACHE
// ============================================================

model TmdbCache {
  id        Int      @id @default(autoincrement())
  cacheKey  String   @unique @map("cache_key") @db.VarChar(200)
  response  Json
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([cacheKey])
  @@index([expiresAt])
  @@map("tmdb_cache")
}

// ============================================================
// EDITORIAL MEDIA
// ============================================================

model Media {
  id         Int      @id @default(autoincrement())
  uploadedBy Int      @map("uploaded_by")
  url        String
  filename   String   @db.VarChar(255)
  mimeType   String   @map("mime_type") @db.VarChar(50)
  fileSize   Int?     @map("file_size")
  width      Int?
  height     Int?
  altText    String?  @map("alt_text") @db.VarChar(300)
  credit     String?  @db.VarChar(200)
  createdAt  DateTime @default(now()) @map("created_at")

  uploadedByUser User @relation(fields: [uploadedBy], references: [id])

  @@map("media")
}

// ============================================================
// SITE SETTINGS
// ============================================================

model AppSetting {
  key       String   @id @db.VarChar(100)
  value     Json
  updatedAt DateTime @default(now()) @map("updated_at")

  @@map("app_settings")
}

// ============================================================
// COLLECTIONS
// ============================================================

model Collection {
  id            Int      @id @default(autoincrement())
  slug          String   @unique @db.VarChar(100)
  title         String   @db.VarChar(200)
  description   String?
  coverImageUrl String?  @map("cover_image_url")
  sortOrder     Int      @default(0) @map("sort_order")
  isVisible     Boolean  @default(true) @map("is_visible")
  createdAt     DateTime @default(now()) @map("created_at")

  articles CollectionArticle[]

  @@map("collections")
}

model CollectionArticle {
  collectionId Int @map("collection_id")
  articleId    Int @map("article_id")
  sortOrder    Int @default(0) @map("sort_order")

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  article    Article    @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@id([collectionId, articleId])
  @@map("collection_articles")
}
