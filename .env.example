# ============================================================
# Core
# ============================================================
NODE_ENV=development
APP_URL=http://localhost:3000
DATABASE_URL=postgresql://postgres:password@localhost:5432/cinefiles
JWT_SECRET=change-me-in-production
SESSION_SECRET=change-me-in-production

# ============================================================
# Auth — Yandex OAuth
# ============================================================
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=

# ============================================================
# Auth — VK ID
# ============================================================
VK_CLIENT_ID=
VK_CLIENT_SECRET=

# ============================================================
# Auth — Telegram Login Widget
# ============================================================
TELEGRAM_BOT_TOKEN=

# ============================================================
# Storage — Yandex S3
# ============================================================
YANDEX_S3_ENDPOINT=https://storage.yandexcloud.net
YANDEX_S3_REGION=ru-central1
YANDEX_S3_BUCKET=cinefiles-media
YANDEX_S3_ACCESS_KEY=
YANDEX_S3_SECRET_KEY=

# ============================================================
# TMDB Proxy
# ============================================================
TMDB_API_KEY=
TMDB_PROXY_URL=https://cinefiles.vercel.app/api/tmdb
TMDB_PROXY_SECRET=

# ============================================================
# TR-BUTE Integration
# ============================================================
TRIBUTE_API_URL=https://buy-tribute.com/api
TRIBUTE_API_KEY=

# ============================================================
# Redis (Optional)
# ============================================================
REDIS_URL=

# ============================================================
# Email (Yandex Postbox)
# ============================================================
POSTBOX_API_KEY_ID=
POSTBOX_API_KEY_SECRET=
NOTIFICATION_FROM_EMAIL=noreply@cinefiles.ru
